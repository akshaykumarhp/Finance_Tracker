# Copy this file to .env.local and fill in values from your Supabase project
# (Supabase Dashboard -> Project Settings -> API)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ---------------------------------------------------------------------------
# OPTIONAL: rate limiting (login/signup abuse protection).
# Leave blank to disable — the app works fine without it.
# Create a free Redis DB at https://upstash.com and paste the REST creds:
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
